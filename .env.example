# Server
PORT=3000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Pipedrive (Sales CRM)
PIPEDRIVE_API_TOKEN=...
PIPEDRIVE_DOMAIN=yourcompany

# Monday.com (Support)
MONDAY_API_KEY=...
MONDAY_BOARD_ID=...

# Alerts (Manager)
ALERT_EMAIL=manager@tarbutu.co.il
ALERT_WHATSAPP_PHONE=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Agency
AGENCY_NAME=תרבותו
# Optional: URL to fetch for bot context (default https://tarbutu.co.il)
# WEBSITE_URL=https://tarbutu.co.il
# Optional: extra URLs to crawl first – כל דפי היעדים כדי שהבוט יענה על תאריכים. Comma-separated.
# WEBSITE_SEED_URLS=https://tarbutu.co.il/קרוזים-לפיורדים,https://tarbutu.co.il/הכף-הצפוני,https://tarbutu.co.il/קרוזים-לאיסלנד-והאיים-הבריטיים,https://tarbutu.co.il/קרוזים,https://tarbutu.co.il/טיולי-תרבות,https://tarbutu.co.il/שייט-נהרות,https://tarbutu.co.il/קרוזים-בים-הבלטי,https://tarbutu.co.il/קרוז-לקנדה-מערב-ואלסקה,https://tarbutu.co.il/קרוזים-לאיים-הבריטיים
# Optional: how often to rescan the full site (hours). Default 8.
# WEBSITE_CRAWL_INTERVAL_HOURS=8

# Twilio WhatsApp (אם מוגדר – הבוט עובד דרך Twilio, בלי QR ובלי מגבלת 4 מכשירים)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# לבדיקות עם סנדבוקס – חובה: TWILIO_WHATSAPP_FROM=14155238886
# כשמחברים את המספר שלך – TWILIO_WHATSAPP_FROM=97233823637 (למשל)
# TWILIO_WHATSAPP_FROM=14155238886
